<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payments Toolkit - <%= pageTitle %></title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect x='10' y='20' width='80' height='60' rx='10' fill='%232563eb'/><rect x='15' y='25' width='70' height='50' rx='8' fill='%233b82f6'/><rect x='20' y='30' width='20' height='15' rx='3' fill='%23ffffff'/><rect x='20' y='50' width='40' height='8' rx='2' fill='%23ffffff'/></svg>"/>
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/sidebar.css">
  <script>(function(){var t=localStorage.getItem('payments-theme')||'system';if(t==='system'){t=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';}document.documentElement.setAttribute('data-theme',t);})();</script>
</head>
<body>
  <div class="app-container">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <a href="/" class="site-title"><em>Payments</em> Toolkit</a>
        <button class="sidebar-toggle" id="sidebar-toggle" title="Sidebar einklappen">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 19l-7-7 7-7M18 19l-7-7 7-7"/>
          </svg>
        </button>
      </div>
      <nav class="sidebar-nav">
        <a href="/" class="sidebar-link <%= activePage === 'home' ? 'active' : '' %>" data-page="home">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9,22 9,12 15,12 15,22"/>
          </svg>
          <span>Startseite</span>
        </a>
        <a href="/validate" class="sidebar-link <%= activePage === 'validate' ? 'active' : '' %>" data-page="validate">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22,4 12,14.01 9,11.01"/>
          </svg>
          <span>Validierung</span>
        </a>
        <a href="/statement" class="sidebar-link <%= activePage === 'statement' ? 'active' : '' %>" data-page="statement">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14,2 14,8 20,8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10,9 9,9 8,9"/>
          </svg>
          <span>Auszuege</span>
        </a>
        <a href="/convert" class="sidebar-link <%= activePage === 'convert' ? 'active' : '' %>" data-page="convert">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 16V4M7 4L3 8M7 4L11 8M17 8v12M17 20l4-4M17 20l-4-4"/>
          </svg>
          <span>Konvertierung</span>
        </a>
        <a href="/create" class="sidebar-link <%= activePage === 'create' ? 'active' : '' %>" data-page="create">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="16"/>
            <line x1="8" y1="12" x2="16" y2="12"/>
          </svg>
          <span>Erstellen</span>
        </a>
        <a href="/tools" class="sidebar-link <%= activePage === 'tools' ? 'active' : '' %>" data-page="tools">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
          <span>Tools</span>
        </a>
        <a href="/samples" class="sidebar-link <%= activePage === 'samples' ? 'active' : '' %>" data-page="samples">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 12h20M2 12l5-5M2 12l5 5"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
          <span>Beispieldaten</span>
        </a>
        <a href="/packer" class="sidebar-link <%= activePage === 'packer' ? 'active' : '' %>" data-page="packer">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27,6.96 12,12.01 20.73,6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
          <span>C53 Packer</span>
        </a>
        <a href="/identities" class="sidebar-link <%= activePage === 'identities' ? 'active' : '' %>" data-page="identities">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <span>Identitäten</span>
        </a>
        <a href="/merge" class="sidebar-link <%= activePage === 'merge' ? 'active' : '' %>" data-page="merge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
            <path d="M7 12h10M12 7v10"/>
          </svg>
          <span>Zahlungen zusammenfassen</span>
        </a>
      </nav>
      <div class="sidebar-footer">
        <button id="theme-toggle" class="theme-toggle" title="Farbschema wechseln" aria-label="Farbschema wechseln">
          <span id="theme-icon">◐</span>
          <span id="theme-label">System</span>
        </button>
      </div>
    </aside>

    <main class="main-content">
      <%- body %>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
  <script src="/js/ui_helpers.js"></script>
  <script src="/js/chart_helpers.js"></script>
  <script src="/js/page_home.js"></script>
  <script src="/js/page_validation.js"></script>
  <script src="/js/page_statement.js"></script>
  <script src="/js/page_conversion.js"></script>
  <script src="/js/page_creator.js"></script>
  <script src="/js/page_tools.js"></script>
  <script src="/js/page_samples.js"></script>
  <script src="/js/page_packer.js"></script>
  <script src="/js/page_identities.js"></script>
  <script src="/js/page_merge.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
